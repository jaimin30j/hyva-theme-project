<script>
function blogPostView(urlKey) {
    return {
        post:      null,
        isLoading:   true,
        error:     null,
        notFound:  false,
        copyLabel: '<?= $escaper->escapeJs(__('Copy link')) ?>',

        async init() {
            // If PHP didn't pass the urlKey (edge case),
            // extract it from window.location: /blog/my-slug → my-slug
            if (!urlKey) {
                const parts = window.location.pathname.replace(/\/$/, '').split('/');
                urlKey = parts[parts.length - 1] ?? '';
            }

            // Start reading progress bar tracking
            this.initProgressBar();
            await this.fetchPost();
        },

        async fetchPost() {
            this.isLoading  = true;
            this.error    = null;
            this.notFound = false;

            if (!urlKey) {
                this.notFound = true;
                this.isLoading  = false;
                return;
            }

            // Use POST_DETAIL fragment — includes content field
            // POST_CARD (used on list page) deliberately excludes content
            const query = `
                ${window.BlogFragments.POST_DETAIL}

                query GetBlogPost($url_key: String!) {
                    blogPost(url_key: $url_key) {
                        ...BlogPostDetail
                    }
                }
            `;

            try {
                const res    = await fetch('/graphql', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({
                        query,
                        variables: { url_key: urlKey }
                    })
                });
                const result = await res.json();

                if (result.errors?.length) {
                    const notFoundErr = result.errors.find(
                        e => e.extensions?.category === 'graphql-no-such-entity'
                    );
                    this.notFound = !!notFoundErr;
                    this.error    = notFoundErr ? null : result.errors[0].message;
                } else if (!result.data?.blogPost) {
                    // blogPost returned null — post doesn't exist
                    this.notFound = true;
                } else {
                    this.post = result.data.blogPost;

                    // Update browser tab title with real post title
                    document.title = this.post.title + ' — Blog';

                    // Update meta description for SEO
                    if (this.post.meta_description) {
                        let meta = document.querySelector('meta[name="description"]');
                        if (!meta) {
                            meta = document.createElement('meta');
                            meta.name = 'description';
                            document.head.appendChild(meta);
                        }
                        meta.content = this.post.meta_description;
                    }
                }
            } catch (e) {
                this.error = '<?= $escaper->escapeJs(__('Could not load post. Please try again.')) ?>';
                console.error('[Blog Post View]', e);
            }

            this.isLoading = false;
        },

        // Reading progress bar — fills as user scrolls through the article
        initProgressBar() {
            const bar = document.getElementById('reading-progress');
            if (!bar) return;

            const update = () => {
                const doc    = document.documentElement;
                const total  = doc.scrollHeight - doc.clientHeight;
                const scrolled = total > 0
                    ? (window.scrollY / total) * 100
                    : 0;
                bar.style.width = Math.min(scrolled, 100) + '%';
            };

            window.addEventListener('scroll', update, { passive: true });
            update();
        },

        // Estimated reading time — 200 words per minute average
        readTime() {
            if (!this.post?.content) return 1;
            // Strip HTML tags to count words in plain text only
            const text  = this.post.content.replace(/<[^>]+>/g, ' ');
            const words = text.trim().split(/\s+/).filter(Boolean).length;
            return Math.max(1, Math.ceil(words / 200));
        },

        // First letter of author name for avatar
        authorInitial() {
            return this.post?.author?.charAt(0)?.toUpperCase() ?? '?';
        },

        // Show "updated" badge only if updated_at is meaningfully later than created_at
        wasUpdated() {
            if (!this.post?.updated_at || !this.post?.created_at) return false;
            const created = new Date(this.post.created_at).getTime();
            const updated = new Date(this.post.updated_at).getTime();
            // Show badge only if updated more than 1 hour after creation
            return updated - created > 3600000;
        },

        formatDate(str) {
            if (!str) return '';
            return new Date(str).toLocaleDateString('en-AE', {
                day: 'numeric', month: 'long', year: 'numeric'
            });
        },

        async copyLink() {
            try {
                await navigator.clipboard.writeText(window.location.href);
                this.copyLabel = '<?= $escaper->escapeJs(__('Copied!')) ?>';
                setTimeout(() => {
                    this.copyLabel = '<?= $escaper->escapeJs(__('Copy link')) ?>';
                }, 2000);
            } catch {
                this.copyLabel = '<?= $escaper->escapeJs(__('Copy link')) ?>';
            }
        }
    }
}
</script>