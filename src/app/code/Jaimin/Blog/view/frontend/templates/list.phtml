                    <?= $escaper->escapeHtml(__('Next')) ?> &rarr;
                </button>
            </div>

            <p class="text-right text-xs text-gray-400 mt-3"
               x-text="`Page ${currentPage} of ${totalPages} — ${totalCount} total posts`">
            </p>
        </div>
    </template>
</div>

<script>
function blogList() {
    return {
        isLoading: true,
        posts:       [],
        totalCount:  0,
        totalPages:  1,
        currentPage: 1,
        pageSize:    9,
        error:       null,
        sortField:   'created_at_DESC',
        filters: {
            title:    '',
            author:   '',
            dateFrom: '',
            dateTo:   '',
        },

        async init() {
            const params     = new URLSearchParams(window.location.search);
            this.currentPage = parseInt(params.get('page') ?? '1', 10);
            await this.fetchPosts();
        },

        buildFilter() {
            const filter = { status: { eq: '1' } };

            if (this.filters.title.trim()) {
                filter.title = { match: this.filters.title.trim() };
            }
            if (this.filters.author.trim()) {
                filter.author = { match: this.filters.author.trim() };
            }
            if (this.filters.dateFrom || this.filters.dateTo) {
                filter.created_at = {};
                if (this.filters.dateFrom) {
                    filter.created_at.from = this.filters.dateFrom + ' 00:00:00';
                }
                if (this.filters.dateTo) {
                    filter.created_at.to = this.filters.dateTo + ' 23:59:59';
                }
            }

            return filter;
        },

        buildSort() {
            // 'created_at_DESC' → { created_at: 'DESC' }
            const lastUnderscore = this.sortField.lastIndexOf('_');
            const field     = this.sortField.substring(0, lastUnderscore);
            const direction = this.sortField.substring(lastUnderscore + 1);
            return { [field]: direction };
        },

        async fetchPosts() {
            this.isLoading = true;
            this.error   = null;

            // Prepend fragment definitions, then spread them in the query.
            // window.BlogFragments is loaded by fragments.phtml before this runs.
            const query = `
                ${window.BlogFragments.POST_CARD}
                ${window.BlogFragments.PAGE_INFO}

                query GetBlogPosts(
                    $pageSize: Int!
                    $currentPage: Int!
                    $filter: BlogPostFilterInput
                    $sort: BlogPostSortInput
                ) {
                    blogPosts(
                        pageSize: $pageSize
                        currentPage: $currentPage
                        filter: $filter
                        sort: $sort
                    ) {
                        total_count
                        page_info { ...PageInfoFields }
                        items { ...BlogPostCard }
                    }
                }
            `;

            const variables = {
                pageSize:    this.pageSize,
                currentPage: this.currentPage,
                filter:      this.buildFilter(),
                sort:        this.buildSort(),
            };

            try {
                const res    = await fetch('/graphql', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ query, variables }),
                });
                const result = await res.json();

                if (result.errors?.length) {
                    this.error = result.errors[0].message;
                } else {
                    const data       = result.data.blogPosts;
                    this.posts       = data.items;
                    this.totalCount  = data.total_count;
                    this.totalPages  = data.page_info.total_pages;
                    this.currentPage = data.page_info.current_page;

                    // Sync page number to URL for browser back support
                    const url = new URL(window.location.href);
                    url.searchParams.set('page', this.currentPage);
                    window.history.replaceState({}, '', url);
                }
            } catch (e) {
                this.error = 'Could not load posts. Please try again.';
                console.error('[Blog]', e);
            }

            this.isLoading = false;
        },

        async goToPage(page) {
            if (page < 1 || page > this.totalPages || page === this.currentPage) return;
            this.currentPage = page;
            await this.fetchPosts();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        async resetAndFetch() {
            this.currentPage = 1;
            await this.fetchPosts();
        },

        resetFilters() {
            this.filters   = { title: '', author: '', dateFrom: '', dateTo: '' };
            this.sortField = 'created_at_DESC';
            this.currentPage = 1;
            this.fetchPosts();
        },

        hasActiveFilters() {
            return this.filters.title
                || this.filters.author
                || this.filters.dateFrom
                || this.filters.dateTo
                || this.sortField !== 'created_at_DESC';
        },

        pageNumbers() {
            const total = this.totalPages;
            const cur   = this.currentPage;
            const pages = [];

            if (total <= 7) {
                for (let i = 1; i <= total; i++) pages.push(i);
                return pages;
            }

            pages.push(1);
            if (cur > 4) pages.push('...');

            const start = Math.max(2, cur - 2);
            const end   = Math.min(total - 1, cur + 2);
            for (let i = start; i <= end; i++) pages.push(i);

            if (cur < total - 3) pages.push('...');
            pages.push(total);

            return pages;
        },

        formatDate(str) {
            if (!str) return '';
            return new Date(str).toLocaleDateString('en-AE', {
                day: 'numeric', month: 'short', year: 'numeric'
            });
        },
    }
}
</script>