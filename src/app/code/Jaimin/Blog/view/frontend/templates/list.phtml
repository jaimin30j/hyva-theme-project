                </button>

                <template x-for="page in pageNumbers()" :key="page">
                    <button
                        @click="page !== '...' && goToPage(page)"
                        :class="{
                            'bg-blue-600 text-white border-blue-600': page === currentPage,
                            'hover:bg-gray-50 border-gray-200 cursor-pointer': page !== currentPage && page !== '...',
                            'cursor-default border-transparent': page === '...'
                        }"
                        class="btn-secondary border-1 border-gray-300 rounded-3xl p-2 text-sm min-w-9.5"
                        x-text="page"
                    ></button>
                </template>

                <button
                    @click="goToPage(currentPage + 1)"
                    :disabled="currentPage >= totalPages"
                    class="px-4 py-2 rounded-lg border text-sm
