<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Blog</title>
    </head>
    <body>
        <referenceContainer name="content">

            <!--
                Block 1: loads blog-fragments.js into <head>
                Must appear before the list block so the JS is available
                when Alpine.js initialises the component.
            -->
            <block class="Magento\Framework\View\Element\Template"
                   name="blog.fragments"
                   template="Jaimin_Blog::js/fragments.phtml"
                   before="blog.list"/>

            <!--
                Block 2: the Alpine.js blog list component
            -->
            <block class="Magento\Framework\View\Element\Template" name="blog.list" template="Jaimin_Blog::list.phtml">
                <block name="loading" template="Hyva_Theme::ui/loading.phtml"/>
            </block>

        </referenceContainer>
    </body>
</page>
