<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="custom_testimonials" resource="default" engine="innodb" comment="Custom Testimonials">
        <column xsi:type="int" name="testimonial_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Testimonial ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Testimonial Author Name"/>
        <column xsi:type="varchar" name="email" nullable="true" length="255" comment="Author Email"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Testimonial Title"/>
        <column xsi:type="text" name="content" nullable="false" comment="Testimonial Content"/>
        <column xsi:type="smallint" name="rating" nullable="false" default="5" comment="Testimonial Rating (1-5)"/>
        <column xsi:type="varchar" name="image_path" nullable="true" length="255" comment="Author Image Path"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation Time"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Update Time"/>
        <column xsi:type="smallint" name="sort_order" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="testimonial_id"/>
        </constraint>
        <index referenceId="IDX_CUSTOM_TESTIMONIALS_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
        <index referenceId="IDX_CUSTOM_TESTIMONIALS_SORT_ORDER" indexType="btree">
            <column name="sort_order"/>
        </index>
    </table>
</schema>
