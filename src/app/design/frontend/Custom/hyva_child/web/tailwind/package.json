{
  "name": "@hyva-themes/magento2-default-theme",
  "version": "3.0.0",
  "description": "Hyvä-Themes Default Theme, a TailwindCSS and Alpine.js based Magento frontend theme that makes eCommerce happy.",
  "type": "module",
  "dependencies": {
    "@hyva-themes/hyva-modules": "^1.3.0",
    "@tailwindcss/cli": "^4.1.17",
    "tailwindcss": "^4.1.17"
  },
  "scripts": {
    "start": "npm run watch",
    "generate": "npx hyva-sources && npx hyva-tokens",
    "prewatch": "npm run generate",
    "watch": "npx tailwindcss -i tailwind-source.css -o ../css/styles.css --watch",
    "browser-sync": "npx browser-sync start --config ./browser-sync.config.cjs",
    "prebuild": "npm run generate",
    "build": "npx tailwindcss -i tailwind-source.css -o ../css/styles.css --minify",
    "build-email": "npx postcss --config ./emails emails/email-source.css -o ../css/source/_theme.less"
  },
  "engine-strict": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": [
    "> 0.5% and not dead"
  ],
  "author": "Hyvä Themes BV",
  "license": "proprietary",
  "private": true,
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
